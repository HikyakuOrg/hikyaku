NEXT_PUBLIC_SUPABASE_URL=xxxx
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY=xxxxx

# Leave blank to use default OSM tiles
NEXT_PUBLIC_OSM_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# Valhalla routing engine (server-side only).
VALHALLA_URL=http://localhost:8002

# Tenant root domain. Tenants are reached at <slug>.<root>.
#   prod:  hikyaku.org
#   local: lvh.me:3000  (lvh.me + *.localhost resolve to 127.0.0.1, no hosts edit)
NEXT_PUBLIC_ROOT_DOMAIN=hikyaku.org

# Base URL of the whendan-api backend (server-side only).
WHENDAN_API_URL=http://localhost:3001